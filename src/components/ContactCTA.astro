---
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'See it in action',
  sub = 'Get in touch and we\'ll show you how Intendant fits your procurement workflow.',
} = Astro.props;
---

<section class="bg-navy py-16 sm:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-display font-bold text-3xl sm:text-4xl text-white uppercase tracking-wide mb-4">
      {heading}
    </h2>
    <p class="font-body text-lg text-white/70 mb-8">
      {sub}
    </p>
    <a
      href="/contact"
      class="inline-block px-8 py-3.5 bg-brass text-navy font-display font-bold uppercase text-sm tracking-[0.08em] rounded hover:bg-brass-dark transition-colors duration-200"
    >
      Get in touch
    </a>
  </div>
</section>
