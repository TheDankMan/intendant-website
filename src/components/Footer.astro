---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="wordmark" style="color:#fff; margin-bottom:16px;">Intendant</div>
        <p style="font-size:14px; max-width:32ch; line-height:1.5; margin:0;">
          Procurement software for organisations that buy from more than one supplier. Built in the UK.
        </p>
      </div>
      <div>
        <h4>Product</h4>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
          <li><a href="/how-it-works">How it works</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/contact">Book a walkthrough</a></li>
        </ul>
      </div>
      <div>
        <h4>Company</h4>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
          <li><a href="mailto:info@intendant.uk">info@intendant.uk</a></li>
          <li><span style="color:rgba(255,255,255,0.5);">A product of TVET Training Systems UK Ltd</span></li>
        </ul>
      </div>
      <div>
        <h4>Status</h4>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
          <li style="display:flex; align-items:center; gap:8px;">
            <span style="width:8px; height:8px; border-radius:999px; background:#4ADE80; box-shadow:0 0 0 3px rgba(74,222,128,.18);"></span>
            <span>All systems operational</span>
          </li>
          <li><span style="color:rgba(255,255,255,0.5);">UK-hosted · ISO 27001 aligned</span></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} TVET Training Systems UK Ltd. All rights reserved.</span>
      <span>Intendant™ is a registered trademark.</span>
    </div>
  </div>
</footer>
