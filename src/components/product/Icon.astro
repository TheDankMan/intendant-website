};

const d = ICONS[name] || ICONS.cube;
const paths = d.split(' M').map((seg, i) => (i === 0 ? seg : 'M' + seg));
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={cls}
  style={`stroke:${color || 'currentColor'}; fill:none; stroke-width:${strokeWidth}; stroke-linecap:round; stroke-linejoin:round; flex:0 0 auto; ${style || ''}`}
  aria-hidden="true"
>
  {paths.map((p) => <path d={p} />)}
</svg>
