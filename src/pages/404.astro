---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Intendant">
  <section class="bg-surface py-32 text-center">
    <p class="font-display font-bold text-7xl text-brass/30 mb-4">404</p>
    <h1 class="font-display font-bold text-3xl text-navy uppercase tracking-wide mb-4">Page not found</h1>
    <p class="font-body text-base text-muted mb-8">That page doesn't exist. Head back to the homepage.</p>
    <a href="/" class="px-6 py-3 bg-navy text-white font-display font-semibold uppercase text-sm tracking-[0.06em] rounded hover:bg-navy-mid transition-colors duration-200">
      Back to home
    </a>
  </section>
</BaseLayout>
