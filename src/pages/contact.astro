---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/product/Icon.astro';
---

<BaseLayout title="Contact — Intendant">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow muted">Get in touch</div>
      <h1>30 minutes. Your suppliers. Real screens.</h1>
      <p class="lede">
        We'd rather show you the product against your actual workflow than send a brochure. Tell us a bit about your setup and we'll come back the same working day.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="form-grid">
        <div>
          <form id="contact-form">
            <div class="form-row">
              <div class="form-field">
                <label>Your name <span class="req">*</span></label>
                <input type="text" required placeholder="Jane Smith" />
              </div>
              <div class="form-field">
                <label>Company <span class="req">*</span></label>
                <input type="text" required placeholder="Acme Ltd" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label>Work email <span class="req">*</span></label>
                <input type="email" required placeholder="jane@acme.co.uk" />
              </div>
              <div class="form-field">
                <label>Phone <span style="color:var(--text-muted); font-weight:400; text-transform:none; letter-spacing:0;">(optional)</span></label>
                <input type="tel" placeholder="+44 20 1234 5678" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label>Active suppliers</label>
                <select>
                  <option value="" disabled selected>Roughly how many?</option>
                  <option>1–3 suppliers</option>
                  <option>4–10 suppliers</option>
                  <option>10+ suppliers</option>
                </select>
              </div>
              <div class="form-field">
                <label>Team size</label>
                <select>
                  <option value="" disabled selected>Headcount placing orders</option>
                  <option>1–10</option>
                  <option>10–50</option>
                  <option>50–200</option>
                  <option>200+</option>
                </select>
              </div>
            </div>
            <div class="form-field">
              <label>What's the most painful bit right now?</label>
              <textarea placeholder="Where do orders live today? Which step costs you the most time? Anything specific about your suppliers or jobs we should know?"></textarea>
            </div>
            <button type="submit" class="btn btn-secondary" style="margin-top:8px;">Send message</button>
            <p style="font-size:12px; color:var(--text-muted); margin-top:16px;">
              We reply within one working day. No mailing list, no drip sequence.
            </p>
          </form>
          <div id="contact-sent" style="display:none; padding:40px 0;">
            <div style="width:56px; height:56px; background:var(--mw-50); border-radius:999px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
              <Icon name="check" size={28} color="var(--mw-500)" strokeWidth={2.5} />
            </div>
            <h2 style="font-family:var(--font-display); font-weight:700; font-size:32px; text-transform:uppercase; color:var(--mw-500); margin:0 0 10px;">Message sent.</h2>
            <p style="color:var(--text-secondary); font-size:16px;">We'll come back to you the same working day.</p>
          </div>
        </div>

        <aside class="contact-side">
          <h4>How we usually start</h4>
          <p style="color:var(--text-secondary); font-size:14px; margin:0 0 18px;">
            A 30-minute call where we walk through Intendant using your real supplier list and one of your active jobs. No slide decks.
          </p>
          <div class="item">
            <div class="item-icon"><Icon name="mail" size={14} /></div>
            <div>
              <div class="lbl">Email</div>
              <div class="val"><a href="mailto:info@intendant.uk" style="color:var(--mw-500); font-weight:600;">info@intendant.uk</a></div>
            </div>
          </div>
          <div class="item">
            <div class="item-icon"><Icon name="clock" size={14} /></div>
            <div>
              <div class="lbl">Response time</div>
              <div class="val">Within one working day</div>
            </div>
          </div>
          <div class="item">
            <div class="item-icon"><Icon name="grid" size={14} /></div>
            <div>
              <div class="lbl">Where we are</div>
              <div class="val">London · Glasgow · UK-only data hosting</div>
            </div>
          </div>
          <div class="item">
            <div class="item-icon"><Icon name="user" size={14} /></div>
            <div>
              <div class="lbl">Who you'll speak to</div>
              <div class="val">A founder, not a sales rep</div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const sent = document.getElementById('contact-sent');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    if (sent) sent.style.display = 'block';
  });
</script>
