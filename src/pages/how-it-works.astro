---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/product/Icon.astro';
import CatalogueScreen from '../components/product/CatalogueScreen.astro';
import BasketDrawerMock from '../components/product/BasketDrawerMock.astro';
import HistoryScreen from '../components/product/HistoryScreen.astro';
import DeliveryDocketMock from '../components/product/DeliveryDocketMock.astro';
import InvoiceMatchMock from '../components/product/InvoiceMatchMock.astro';

const rail = [
  'Set up suppliers & catalogue',
  'Staff place orders by job',
  'Orders route as structured POs',
  'Deliveries arrive, dockets captured',
  'Invoices match against POs',
];

const steps = [
  {
    n: '01',
    title: 'Set up suppliers and the catalogue',
    body: 'We import your existing price lists and supplier records. Each item gets a primary supplier plus optional alternates, with the agreed unit prices and quantity bands attached.',
    bullets: [
      'CSV / Excel price-book import',
      'Per-item supplier mapping with alternates',
      'Quantity bands, units, and pack sizes',
      'Contract expiry dates with renewal alerts',
    ],
    caption: 'Catalogue editor',
  },
  {
    n: '02',
    title: 'Staff place orders against job codes',
    body: 'Team members log in, browse the catalogue, and add items to the basket. Before submission, every order is tagged to a job code — captured once and stamped on every line.',
    bullets: [
      'Catalogue search by name, code, supplier, or recent',
      'Job code captured on submit, not after the fact',
      'Quantity steppers with gloved-hand tap targets',
      "'In basket' badges prevent duplicate adds",
    ],
    caption: 'Order basket',
  },
  {
    n: '03',
    title: 'Orders route to suppliers as structured POs',
    body: "When the order goes out, Intendant splits it by supplier and generates a clean purchase order for each. Suppliers see exactly what's ordered, where it's going, when it's needed.",
    bullets: [
      'One PO per supplier, auto-numbered',
      'Delivery address pulled from the job',
      'Required-by date captured at order time',
      'Buyers see all open POs in one view',
    ],
    caption: 'Open POs',
  },
  {
    n: '04',
    title: 'Deliveries arrive — dockets captured on arrival',
    body: 'The driver or site contact uploads a delivery docket photo from their phone. The system reads quantities off the docket and links them to the originating order.',
    bullets: [
      'Photo upload from any phone',
      'Auto-link to the original order by reference',
      'Part deliveries tracked at the line level',
      'Overdue deliveries flagged in red',
    ],
    caption: 'Proof of delivery',
  },
  {
    n: '05',
    title: 'Invoices match against POs',
    body: 'When the supplier invoice lands, accounts pulls it into Intendant. Lines are matched against PO and docket. Discrepancies surface immediately — quantity mismatches, price drift, ghost items.',
    bullets: [
      'Three-way line match: PO ↔ docket ↔ invoice',
      'Price drift checked against agreed price book',
      'Flagged invoices held for review, not paid',
      'Approved matches push to your accounts tool',
    ],
    caption: 'Invoice reconciliation',
  },
];

const roles = [
  { tag: 'ROLE 01', title: 'Site managers', desc: 'Place orders against assigned jobs. Track open deliveries.', list: ['Catalogue search', 'Order basket', 'Own order history', 'PoD uploads'] },
  { tag: 'ROLE 02', title: 'Buyers', desc: 'Full order visibility. Manage suppliers, catalogue, and price books.', list: ['All open POs', 'Catalogue manager', 'Supplier price books', 'User access'] },
  { tag: 'ROLE 03', title: 'Accounts', desc: 'Match invoices, reconcile deliveries, produce spend reports.', list: ['Invoice match', 'Delivery dockets', 'Spend reports', 'CSV export'] },
  { tag: 'ROLE 04', title: 'Admins', desc: 'Org-wide settings, integrations, audit logs, retention policies.', list: ['User & role admin', 'Accounting integration', 'Audit log', 'Data retention'] },
];
---

<BaseLayout title="How it works — Intendant">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow muted">How it works</div>
      <h1>Catalogue → Order → Delivery → Match</h1>
      <p class="lede">
        The procurement loop, in five steps. Set up takes a week. The daily workflow takes minutes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container how-grid" style="display:grid; grid-template-columns:minmax(320px, 1fr) 2fr; gap:64px;">
      <aside style="position:sticky; top:96px; align-self:start;">
        <div class="eyebrow accent" style="margin-bottom:16px;">The five steps</div>
        <ol style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:14px;">
          {rail.map((s, i) => (
            <li style="display:grid; grid-template-columns:32px 1fr; gap:12px; font-size:15px; align-items:center;">
              <span style="font-family:var(--font-display); font-weight:700; width:32px; height:32px; border-radius:6px; background:var(--mw-500); color:var(--accent); display:flex; align-items:center; justify-content:center; font-size:14px; letter-spacing:0.05em;">0{i + 1}</span>
              <span style="color:var(--text-primary);">{s}</span>
            </li>
          ))}
        </ol>
        <div style="margin-top:32px; padding:20px; background:var(--mw-500); color:#fff; border-radius:12px;">
          <div class="eyebrow" style="color:var(--accent);">Typical setup time</div>
          <div style="font-family:var(--font-display); font-weight:700; font-size:40px; line-height:1; margin:10px 0 4px; color:#fff;">5 days</div>
          <p style="margin:0; font-size:13px; color:rgba(255,255,255,0.72);">From kick-off to first live order. We handle the supplier price-book imports.</p>
        </div>
      </aside>

      <div class="step-rail">
        {steps.map((s, i) => (
          <div class="step-item">
            <div class="meta">STEP {s.n}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <ul style="list-style:none; padding:0; margin:14px 0 22px; display:grid; grid-template-columns:1fr 1fr; gap:8px;">
              {s.bullets.map((b) => (
                <li style="display:grid; grid-template-columns:16px 1fr; gap:8px; font-size:13px; color:var(--text-primary);">
                  <Icon name="check" size={14} color="var(--accent)" strokeWidth={2.5} />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <div class="shot">
              <div class="inner">
                {i === 0 && <CatalogueScreen />}
                {i === 1 && (
                  <div style="background:var(--canvas); height:440px; padding:16px;">
                    <div style="height:100%; max-width:360px; margin-left:auto; background:#fff; border:1px solid var(--border); border-radius:8px; overflow:hidden;">
                      <BasketDrawerMock />
                    </div>
                  </div>
                )}
                {i === 2 && <HistoryScreen />}
                {i === 3 && (
                  <div style="background:var(--canvas); height:440px; padding:24px; display:flex; align-items:center;">
                    <DeliveryDocketMock />
                  </div>
                )}
                {i === 4 && (
                  <div style="background:var(--canvas); height:440px; padding:24px; display:flex; align-items:center;">
                    <InvoiceMatchMock />
                  </div>
                )}
              </div>
            </div>
            <div class="shot-caption"><span class="mono">{s.caption}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-canvas">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Role-based access</span>
        <h2>Everyone sees what they need. Nothing they don't.</h2>
      </div>
      <div class="roles">
        {roles.map((r) => (
          <div class="role">
            <div class="role-tag">{r.tag}</div>
            <h4>{r.title}</h4>
            <p>{r.desc}</p>
            <ul class="role-list">
              {r.list.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Want to see your workflow in it?"
    sub="Send us your current process — phone, email, spreadsheet — and we'll show you the same thing in Intendant."
  />
</BaseLayout>
