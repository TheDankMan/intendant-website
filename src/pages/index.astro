---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<BaseLayout title="Intendant — Every order. Every supplier. One place.">

  <!-- Hero -->
  <section class="bg-navy pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-display font-semibold uppercase text-xs tracking-widest text-brass mb-5">
        Procurement software for multi-supplier teams
      </p>
      <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl text-white uppercase leading-none tracking-wide mb-6">
        Every order.<br class="hidden sm:block" /> Every supplier.<br class="hidden sm:block" /> One place.
      </h1>
      <p class="font-body text-lg sm:text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        Intendant is a procurement portal for teams that buy from multiple suppliers.
        Order by job, track deliveries, and match invoices — without the spreadsheets and email chains.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/contact"
          class="px-8 py-3.5 bg-brass text-navy font-display font-bold uppercase text-sm tracking-[0.08em] rounded hover:bg-brass-dark transition-colors duration-200"
        >
          Get in touch
        </a>
        <a
          href="/how-it-works"
          class="px-8 py-3.5 border border-white/20 text-white font-display font-semibold uppercase text-sm tracking-[0.08em] rounded hover:border-white/40 hover:bg-white/5 transition-colors duration-200"
        >
          How it works
        </a>
      </div>
    </div>
  </section>

  <!-- Problem statement -->
  <section class="bg-surface-2 py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="font-display font-semibold uppercase text-xs tracking-widest text-slate mb-3">The problem</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy uppercase tracking-wide">
          Buying from more than three suppliers?<br class="hidden sm:block" /> You already know what this costs you.
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
        {[
          'Orders placed by phone, email, and WhatsApp — with no audit trail',
          'Price books living in spreadsheets no one trusts',
          'Deliveries arriving at site with nobody knowing which job they were for',
          'Month-end spent manually matching invoices across five different inboxes',
          'No visibility of what\'s been ordered until it arrives — or doesn\'t',
          'Staff ordering the wrong items because the catalogue lives in someone\'s head',
        ].map((point) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate/10">
            <svg class="w-5 h-5 text-brass shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <p class="font-body text-sm text-body-text leading-snug">{point}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="font-display font-semibold uppercase text-xs tracking-widest text-slate mb-3">What Intendant does</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy uppercase tracking-wide">
          End-to-end procurement.<br class="hidden sm:block" /> No moving parts you don't control.
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />`,
            title: 'Supplier catalogue',
            body: 'One searchable catalogue covering all your suppliers. Staff order from a single interface — Intendant routes each line to the right supplier automatically.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />`,
            title: 'Order by job',
            body: 'Every order is tagged to a job or project code. See exactly what\'s been ordered, by whom, for which job — and total spend per project at a glance.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
            title: 'Supplier price books',
            body: 'Upload price lists per supplier. Intendant applies the agreed price automatically and alerts you when contracts are approaching expiry.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />`,
            title: 'Delivery tracking',
            body: 'Drivers upload proof-of-delivery photos from their phone. Every delivery is timestamped and linked to the original order — no more chasing paperwork.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
            title: 'Invoice matching',
            body: 'Match supplier invoices against purchase orders line by line. Discrepancies are flagged before they reach the accounts team — not after.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
            title: 'Spend reporting',
            body: 'Spend by supplier, by job, by date range — filtered and exported in seconds. The data your finance team needs without them having to ask for it.',
          },
        ].map((feature) => (
          <div class="bg-surface-2 rounded-xl p-6 border border-slate/10">
            <div class="w-10 h-10 bg-navy/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={feature.icon} />
            </div>
            <h3 class="font-display font-bold text-lg text-navy uppercase tracking-wide mb-2">
              {feature.title}
            </h3>
            <p class="font-body text-sm text-muted leading-relaxed">
              {feature.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works (summary) -->
  <section class="bg-surface-2 py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="font-display font-semibold uppercase text-xs tracking-widest text-slate mb-3">The workflow</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy uppercase tracking-wide">
          Set up once. Use it every day.
        </h2>
      </div>
      <ol class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { n: '01', title: 'Set up your catalogue', body: 'Import your supplier items and price books. One-time setup — Intendant keeps everything in sync as prices change.' },
          { n: '02', title: 'Staff place orders by job', body: 'Team members browse the catalogue, select items, and tag the order to a job code. No phone calls needed.' },
          { n: '03', title: 'Orders go to suppliers', body: 'Intendant routes each line to the right supplier as a structured purchase order. You get a full audit trail.' },
          { n: '04', title: 'Track, receive, and reconcile', body: 'Deliveries are confirmed with proof-of-delivery photos. Invoices are matched automatically against POs.' },
        ].map((step) => (
          <li class="flex gap-5 bg-white rounded-xl p-6 border border-slate/10">
            <span class="font-display font-bold text-3xl text-brass/40 leading-none shrink-0 w-8">{step.n}</span>
            <div>
              <h3 class="font-display font-bold text-lg text-navy uppercase tracking-wide mb-1">{step.title}</h3>
              <p class="font-body text-sm text-muted leading-relaxed">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="text-center mt-8">
        <a href="/how-it-works" class="font-display font-semibold uppercase text-sm tracking-[0.06em] text-slate hover:text-navy transition-colors duration-200">
          Full walkthrough →
        </a>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="font-display font-semibold uppercase text-xs tracking-widest text-slate mb-3">Who it's for</p>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy uppercase tracking-wide">
          Built for organisations that order at volume
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { title: '3+ active suppliers', body: 'If you\'re coordinating orders across multiple suppliers, Intendant gives you one place to manage all of them.' },
          { title: 'Project-based buying', body: 'Order lines tagged to job codes mean your finance team always knows what was spent on which project.' },
          { title: '5 to 200 staff', body: 'Role-based access for field staff, buyers, accounts, and delivery — each seeing what they need, nothing they don\'t.' },
        ].map((card) => (
          <div class="text-center px-4">
            <h3 class="font-display font-bold text-xl text-navy uppercase tracking-wide mb-2">{card.title}</h3>
            <p class="font-body text-sm text-muted leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />

</BaseLayout>
