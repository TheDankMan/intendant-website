---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/product/Icon.astro';

const facts = [
  { label: 'Suppliers', val: 'Quoted on count' },
  { label: 'Users', val: 'Unlimited' },
  { label: 'Jobs', val: 'Unlimited' },
  { label: 'Setup fees', val: 'None' },
];

const includes = [
  'Unlimited users across all roles',
  'Unlimited catalogue items and jobs',
  'Supplier price book imports & alerts',
  'PO generation and chase workflows',
  'Proof-of-delivery photo capture',
  'Three-way invoice match',
  'Spend reports & CSV export',
  'Accounting integration (Xero, Sage, QBO)',
  'UK-based support',
  'ISO 27001 aligned infrastructure',
];

const sizes = [
  { size: 'Small', desc: 'Up to 4 suppliers · &lt;200 orders/mo · 1 site', notes: 'Most builders, fit-out, and small civils firms.' },
  { size: 'Mid',   desc: '4–10 suppliers · 200–800 orders/mo · multiple sites', notes: 'Multi-site contractors, FM operators, plant hire.' },
  { size: 'Large', desc: '10+ suppliers · 800+ orders/mo · regional ops', notes: 'Custom scoping; multi-entity rollouts.' },
];

const faqs = [
  { q: 'Is there a setup fee?', a: 'No. Onboarding is included — that covers price-book imports, supplier setup, and user training for your buyers and site staff.' },
  { q: 'What happens if our supplier list grows?', a: "Adding a supplier doesn't necessarily change your tier. Pricing only shifts when sustained order volume or supplier count crosses a band. We'll flag it before it changes." },
  { q: 'Do you charge per user?', a: 'No. Add as many site staff, buyers, accounts users, and admins as you need. We price the organisation, not the headcount.' },
  { q: 'Can we trial it first?', a: 'Yes — a one-month paid pilot with a single supplier and a single site is the most common starting point. Pilot fees credit against the full contract.' },
  { q: 'Where is data hosted?', a: 'UK only. Cloudflare and AWS eu-west-2. Daily encrypted backups; ISO 27001 aligned controls.' },
  { q: "What's the contract term?", a: "12 months minimum after pilot. Monthly thereafter once you've completed the first year." },
];
---

<BaseLayout title="Pricing — Intendant">
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow muted">Pricing</div>
      <h1>One price per organisation. No per-seat games.</h1>
      <p class="lede">
        We scope each quote against your supplier count and order volume. Whether your team is five or fifty, the price doesn't change.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        <div class="pricing-card">
          <span class="eyebrow label" style="color:var(--accent);">How we price</span>
          <h3>Scoped to your operation</h3>
          <p>Pricing is based on active suppliers and order volume. There are no setup fees, no per-seat charges, no caps on jobs, catalogue items, or storage.</p>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:18px; margin:32px 0 28px; position:relative;">
            {facts.map((f) => (
              <div style="border-top:1px solid rgba(255,255,255,0.18); padding-top:10px;">
                <div style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.55); font-weight:600;">{f.label}</div>
                <div style="font-family:var(--font-display); font-weight:600; font-size:22px; color:#fff; margin-top:4px;">{f.val}</div>
              </div>
            ))}
          </div>
          <div style="display:flex; gap:12px; position:relative; flex-wrap:wrap;">
            <a class="btn btn-primary" href="/contact">Get a quote</a>
            <a class="btn btn-ghost" href="/how-it-works">See how it works</a>
          </div>
        </div>

        <div class="pricing-includes">
          <h4>What's always included</h4>
          <ul>
            {includes.map((s) => (
              <li>
                <Icon name="check" size={14} strokeWidth={2.5} />
                {s}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div style="margin-top:64px;">
        <div class="section-head" style="margin-bottom:24px;">
          <span class="eyebrow accent">Sizing</span>
          <h2>Roughly where you sit</h2>
          <p class="lede">A rough sketch — your actual quote depends on supplier count and order volume.</p>
        </div>
        <div class="sizing-grid" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:16px;">
          {sizes.map((s) => (
            <div style="background:#fff; border:1px solid var(--border); border-radius:12px; padding:24px;">
              <div class="eyebrow accent" style="margin-bottom:6px;">{s.size}</div>
              <div style="font-family:var(--font-display); font-weight:700; font-size:22px; text-transform:uppercase; color:var(--mw-500); margin-bottom:10px; line-height:1.1;" set:html={s.desc} />
              <p style="font-size:13px; color:var(--text-secondary); margin:0;">{s.notes}</p>
            </div>
          ))}
        </div>
      </div>

      <div style="margin-top:80px; max-width:800px;">
        <div class="section-head" style="margin-bottom:20px;">
          <span class="eyebrow">Questions we get</span>
          <h2>Pricing FAQs</h2>
        </div>
        {faqs.map((f, i) => (
          <details class="faq" open={i === 0}>
            <summary>{f.q}</summary>
            <div class="answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Want a number?"
    sub="Tell us your supplier count and rough order volume. We come back with a quote the same working day."
  />
</BaseLayout>
